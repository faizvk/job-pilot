# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite file, used when TURSO_DATABASE_URL is not set)
DATABASE_URL="file:./dev.db"

# Turso (production) — https://turso.tech
# turso db create jobpilot
# turso db show jobpilot --url   → TURSO_DATABASE_URL
# turso db tokens create jobpilot → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# ─── AI Providers (add at least one) ─────────────────────────────────────────
GEMINI_API_KEY=         # https://aistudio.google.com/apikey (free)
GROQ_API_KEY=           # https://console.groq.com/keys (free)
OPENAI_API_KEY=         # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=      # https://console.anthropic.com/settings/keys
MISTRAL_API_KEY=        # https://console.mistral.ai/api-keys
DEEPSEEK_API_KEY=       # https://platform.deepseek.com/api_keys
COHERE_API_KEY=         # https://dashboard.cohere.com/api-keys
TOGETHER_API_KEY=       # https://api.together.xyz/settings/api-keys

# ─── Job Search APIs ──────────────────────────────────────────────────────────
RAPIDAPI_KEY=           # https://rapidapi.com (JSearch — free 500 req/month)
ADZUNA_APP_ID=          # https://developer.adzuna.com (free)
ADZUNA_API_KEY=

# ─── Gmail OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   Dev:  http://localhost:3000/api/gmail/callback
#   Prod: https://your-domain.com/api/gmail/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://your-domain.com/api/gmail/callback

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
